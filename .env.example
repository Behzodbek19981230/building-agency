# ================================
# BuildHub — Environment Variables
# ================================

# App
NODE_ENV=development
PORT=3004
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buildhub
POSTGRES_DB=buildhub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=your-super-secret-access-token-change-in-production-64-chars-minimum
JWT_REFRESH_SECRET=your-super-secret-refresh-token-change-in-production-64-chars-minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
AWS_S3_BUCKET=buildhub
AWS_ENDPOINT=http://localhost:9000

# MinIO (local development)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@buildhub.uz

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+12345678901

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# OpenAI (AI features)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# Commission rates
COMMISSION_CLIENT_RATE=0.05
COMMISSION_WORKER_RATE=0.10
